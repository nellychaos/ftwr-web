---
interface Props {
  title: string;
  description: string;
  publishedDate: Date;
  category: string;
  tags: string[];
  slug: string;
  readingTime?: string;
}

const { title, description, publishedDate, category, slug, readingTime } = Astro.props;

const formattedDate = publishedDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const categoryLabel = category.replace(/-/g, ' ');
---

<a href={`/${slug}`} class="post-card">
  <div class="post-card-category">{categoryLabel}</div>
  <h3 class="post-card-title">{title}</h3>
  <p class="post-card-description">{description}</p>
  <div class="post-card-meta">
    <span>{formattedDate}</span>
    {readingTime && <span>{readingTime}</span>}
  </div>
</a>

<style>
  .post-card {
    display: block;
    border: 1px solid rgba(28, 27, 27, 0.12);
    padding: 1.5rem;
    background: white;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }

  .post-card:hover {
    background: var(--surface-container-high);
    text-decoration: none;
  }

  .post-card-category {
    font-family: var(--font-mono);
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--secondary);
    margin-bottom: 0.75rem;
  }

  .post-card-title {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1.2rem;
    letter-spacing: -0.03em;
    color: var(--on-surface);
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .post-card-description {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--on-surface-variant);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .post-card-meta {
    display: flex;
    gap: 1.5rem;
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.4;
  }
</style>
