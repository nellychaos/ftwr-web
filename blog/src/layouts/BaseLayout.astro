---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SpectralBar from '../components/SpectralBar.astro';
import Seo from '../components/Seo.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
  author?: string;
}

const { title, description, ogImage, type, publishedDate, author } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;700;800&display=swap" rel="stylesheet" />
  <link rel="alternate" type="application/rss+xml" title="FTWR Blog" href="/rss.xml" />
  <Seo
    title={title}
    description={description}
    ogImage={ogImage}
    type={type}
    publishedDate={publishedDate}
    author={author}
  />
</head>
<body>
  <Nav />
  <main>
    <slot />
  </main>
  <SpectralBar />
  <Footer />
</body>
</html>
